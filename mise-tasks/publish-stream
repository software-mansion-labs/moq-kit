#!/usr/bin/env bash
#MISE description="Publish a media file to a MOQ relay via ffmpeg"
#USAGE flag "--url <url>" default="http://localhost:4443/anon" help="Relay URL"
#USAGE flag "--name <name>" default="bbb" help="Broadcast name/path"
#USAGE flag "--input <input>" default="bin/shrek.fmp4" help="Input media file"
set -euo pipefail

INPUT=$(realpath "$usage_input")

cd vendor/moq &&
  ffmpeg -hide_banner -v quiet \
    -stream_loop -1 -re \
    -i "$INPUT" \
    -c copy \
    -f mp4 -movflags cmaf+separate_moof+delay_moov+skip_trailer+frag_every_frame - |
  cargo run --bin moq-cli -- publish --url "$usage_url" --name "$usage_name" fmp4
