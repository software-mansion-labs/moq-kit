#!/usr/bin/env bash
#MISE description="Install the Android demo debug APK on a connected device"
set -euo pipefail

if [[ $# -gt 0 ]]; then
  case "$1" in
  -h | --help)
    echo "Usage: android:install"
    echo ""
    echo "Install the Android demo debug APK on a connected device."
    exit 0
    ;;
  *)
    echo "Unknown argument: $1" >&2
    exit 1
    ;;
  esac
fi

cd "$MISE_PROJECT_ROOT/examples/android/demo/MoQDemo"
./gradlew installDebug
