#!/usr/bin/env bash
#MISE description="Build and publish the MoQKit Android AAR to local Maven"
set -euo pipefail

ROOT_DIR="$MISE_PROJECT_ROOT"

echo "==> Building Android AAR..."
mise run android:build

echo "==> Publishing MoQKit AAR to local Maven..."
cd "$ROOT_DIR/android/moqkit"
./gradlew :moqkit:publishToMavenLocal
