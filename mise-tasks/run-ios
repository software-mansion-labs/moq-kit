#!/usr/bin/env bash
#MISE description="Build and run the iOS MoQ Demo on a connected device"
#USAGE flag "--simulator" help="Run on an iPhone simulator instead of a physical device"
set -euo pipefail

ROOT_DIR="$MISE_PROJECT_ROOT"
PROJECT="$ROOT_DIR/examples/ios/demo/MoQDemo.xcodeproj"
SCHEME="MoQDemo"
TARGET="MoQDemo"
DERIVED_DATA_PATH="$ROOT_DIR/.build/DerivedData/MoQDemo"

resolve_build_product() {
  local sdk="$1"
  local settings_json

  settings_json=$(
    xcodebuild -project "$PROJECT" \
      -scheme "$SCHEME" \
      -configuration Debug \
      -sdk "$sdk" \
      -derivedDataPath "$DERIVED_DATA_PATH" \
      -showBuildSettings -json
  )

  local build_info=()
  while IFS= read -r line; do
    build_info+=("$line")
  done < <(
    printf '%s' "$settings_json" | TARGET="$TARGET" python3 -c '
import json
import os
import sys

target = os.environ["TARGET"]
data = json.load(sys.stdin)
for entry in data:
    if entry.get("target") == target:
        settings = entry["buildSettings"]
        print(settings["PRODUCT_BUNDLE_IDENTIFIER"])
        print(settings["TARGET_BUILD_DIR"] + "/" + settings["FULL_PRODUCT_NAME"])
        break
else:
    sys.exit(1)
'
  )

  if [[ ${#build_info[@]} -ne 2 ]]; then
    echo "Failed to resolve build product for $TARGET." >&2
    exit 1
  fi

  BUNDLE_ID="${build_info[0]}"
  APP_PATH="${build_info[1]}"
}

if [[ "${usage_simulator:-false}" = "true" ]]; then
  echo "==> Selecting an iPhone simulator..."
  SIM_INFO=$(xcrun simctl list devices available -j | python3 -c '
import json
import sys

data = json.load(sys.stdin)
iphones = [
    d
    for devices in data["devices"].values()
    for d in devices
    if d["isAvailable"] and d["name"].startswith("iPhone")
]
booted = next((d for d in iphones if d["state"] == "Booted"), None)
chosen = booted or (iphones[0] if iphones else None)
if chosen is None:
    sys.exit(1)
print(chosen["name"])
print(chosen["udid"])
')

  SIM_NAME=$(printf '%s\n' "$SIM_INFO" | sed -n '1p')
  SIM_UDID=$(printf '%s\n' "$SIM_INFO" | sed -n '2p')
  if [[ -z "$SIM_UDID" ]]; then
    echo "No available iPhone simulator found." >&2
    exit 1
  fi

  echo "Simulator: $SIM_NAME ($SIM_UDID)"
  xcrun simctl boot "$SIM_UDID" 2>/dev/null || true

  echo "==> Resolving build product..."
  resolve_build_product "iphonesimulator"

  echo "==> Building $SCHEME for simulator..."
  xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Debug \
    -sdk iphonesimulator \
    -destination "id=$SIM_UDID" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    build

  echo "==> Installing on simulator..."
  xcrun simctl install "$SIM_UDID" "$APP_PATH"
  echo "==> Launching $BUNDLE_ID..."
  xcrun simctl launch "$SIM_UDID" "$BUNDLE_ID"
else
  echo "==> Detecting connected iPhone..."
  DEVICE_UDID=$(xcrun xctrace list devices 2>/dev/null | grep "iPhone" | grep -v "Simulator" | grep -E "^\S.+\([0-9A-F-]+\)$" | head -1 | sed 's/.*(\([0-9A-F-]*\))$/\1/')

  if [[ -z "$DEVICE_UDID" ]]; then
    echo "No real iPhone found. Use --simulator to target a simulator instead." >&2
    exit 1
  fi
  echo "Device: $DEVICE_UDID"

  echo "==> Resolving build product..."
  resolve_build_product "iphoneos"

  echo "==> Building $SCHEME for device..."
  xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Debug \
    -sdk iphoneos \
    -destination "id=$DEVICE_UDID" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    build

  echo "==> Installing on device..."
  xcrun devicectl device install app --device "$DEVICE_UDID" "$APP_PATH"
  echo "==> Launching $BUNDLE_ID..."
  xcrun devicectl device process launch --device "$DEVICE_UDID" "$BUNDLE_ID"
fi

echo "Done."
