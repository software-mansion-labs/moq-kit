#!/usr/bin/env bash
#MISE description="Build and run the iOS publisher or subscriber demo on a connected device"
#USAGE flag "--app <app>" default="subscriber" help="App to run: subscriber or publisher"
#USAGE flag "--simulator" help="Run on the iPhone simulator instead of a physical device"
set -euo pipefail

ROOT_DIR="$MISE_PROJECT_ROOT"
APP="${usage_app:-subscriber}"

case "$APP" in
publisher | subscriber) ;;
*)
  echo "Unknown app: $APP. Expected publisher or subscriber." >&2
  exit 1
  ;;
esac

case "$APP" in
subscriber)
  PROJECT="$ROOT_DIR/examples/ios/subscriber/MoQSubscriber.xcodeproj"
  SCHEME="MoQSubscriber"
  TARGET="MoQSubscriber"
  ;;
publisher)
  PROJECT="$ROOT_DIR/examples/ios/publisher/MoQPublisher.xcodeproj"
  SCHEME="MoQPublisher"
  TARGET="MoQPublisher"
  ;;
esac

DERIVED_DATA_PATH="$ROOT_DIR/.build/DerivedData/$APP"

resolve_build_product() {
  local sdk="$1"
  local settings_json

  settings_json=$(
    xcodebuild -project "$PROJECT" \
      -scheme "$SCHEME" \
      -configuration Debug \
      -sdk "$sdk" \
      -derivedDataPath "$DERIVED_DATA_PATH" \
      -showBuildSettings -json
  )

  local build_info=()
  while IFS= read -r line; do
    build_info+=("$line")
  done < <(
    printf '%s' "$settings_json" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
settings = data[0]["buildSettings"]
print(settings["PRODUCT_BUNDLE_IDENTIFIER"])
print(settings["TARGET_BUILD_DIR"] + "/" + settings["FULL_PRODUCT_NAME"])
'
  )

  if [[ ${#build_info[@]} -ne 2 ]]; then
    echo "Failed to resolve build product for $TARGET." >&2
    exit 1
  fi

  BUNDLE_ID="${build_info[0]}"
  APP_PATH="${build_info[1]}"
}

if [[ "${usage_simulator:-false}" = "true" ]]; then
  echo "==> Using simulator for $APP..."
  SIM_NAME="iPhone 16"

  SIM_UDID=$(xcrun simctl list devices available -j | python3 -c "
import json, sys
data = json.load(sys.stdin)
for runtime, devices in data['devices'].items():
    for d in devices:
        if d['name'] == '$SIM_NAME' and d['isAvailable']:
            print(d['udid']); sys.exit(0)
sys.exit(1)
")

  echo "Simulator: $SIM_NAME ($SIM_UDID)"
  xcrun simctl boot "$SIM_UDID" 2>/dev/null || true

  echo "==> Resolving build product..."
  resolve_build_product "iphonesimulator"

  echo "==> Building $SCHEME for simulator..."
  xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Debug \
    -sdk iphonesimulator \
    -destination "id=$SIM_UDID" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    build

  echo "==> Installing on simulator..."
  xcrun simctl install "$SIM_UDID" "$APP_PATH"
  echo "==> Launching $BUNDLE_ID..."
  xcrun simctl launch "$SIM_UDID" "$BUNDLE_ID"
else
  echo "==> Detecting connected device for $APP..."
  DEVICE_UDID=$(xcrun xctrace list devices 2>/dev/null | grep "iPhone" | grep -v "Simulator" | grep -E "^\S.+\([0-9A-F-]+\)$" | head -1 | sed 's/.*(\([0-9A-F-]*\))$/\1/')

  if [[ -z "$DEVICE_UDID" ]]; then
    echo "No real device found. Use --simulator to target a simulator instead." >&2
    exit 1
  fi
  echo "Device: $DEVICE_UDID"

  echo "==> Resolving build product..."
  resolve_build_product "iphoneos"

  echo "==> Building $SCHEME for device..."
  xcodebuild -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Debug \
    -sdk iphoneos \
    -destination "id=$DEVICE_UDID" \
    -derivedDataPath "$DERIVED_DATA_PATH" \
    build

  echo "==> Installing on device..."
  xcrun devicectl device install app --device "$DEVICE_UDID" "$APP_PATH"
  echo "==> Launching $BUNDLE_ID..."
  xcrun devicectl device process launch --device "$DEVICE_UDID" "$BUNDLE_ID"
fi

echo "Done."
