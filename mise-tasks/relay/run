#!/usr/bin/env bash
#MISE description="Run the local moq-lite relay from vendor/moq"
set -euo pipefail

if [[ $# -gt 0 ]]; then
  case "$1" in
  -h | --help)
    echo "Usage: relay:run"
    echo ""
    echo "Run the local moq-lite relay from vendor/moq."
    exit 0
    ;;
  *)
    echo "Unknown argument: $1" >&2
    exit 1
    ;;
  esac
fi

cd "$MISE_PROJECT_ROOT/vendor/moq"
just relay
